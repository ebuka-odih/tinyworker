{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://tinyworker-production.up.railway.app/api/$1"
    },
    {
      "src": "^/$",
      "dest": "/landing.html"
    },
    {
      "src": "^/jobs/?$",
      "dest": "/jobs.html"
    },
    {
      "src": "^/scholarships/?$",
      "dest": "/scholarships.html"
    },
    {
      "src": "^/grants/?$",
      "dest": "/grants.html"
    },
    {
      "src": "^/visa-guidance/?$",
      "dest": "/visa-guidance.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
